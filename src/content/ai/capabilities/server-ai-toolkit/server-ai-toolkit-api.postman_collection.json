{
  "info": {
    "_postman_id": "server-ai-toolkit-api",
    "name": "Server AI Toolkit API",
    "description": "Postman collection for the Tiptap Server AI Toolkit REST API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Fetch tool definitions",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{JWT_TOKEN}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"editorContext\": {},\n  \"tools\": {\n    \"tiptapRead\": true,\n    \"tiptapEdit\": true\n  },\n  \"format\": \"json\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/v4/ai/toolkit/fetch-tools",
          "host": ["{{BASE_URL}}"],
          "path": ["v4", "ai", "toolkit", "fetch-tools"]
        },
        "description": "Fetch the system prompt and tool definitions for the Server AI Toolkit."
      }
    },
    {
      "name": "Execute a tool",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{JWT_TOKEN}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"editorContext\": {},\n  \"document\": {\n    \"type\": \"inline\",\n    \"content\": {\n      \"type\": \"doc\",\n      \"content\": []\n    }\n  },\n  \"tool\": {\n    \"name\": \"tiptapRead\",\n    \"input\": {\n      \"from\": 0\n    }\n  },\n  \"format\": \"json\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/v4/ai/toolkit/execute-tool",
          "host": ["{{BASE_URL}}"],
          "path": ["v4", "ai", "toolkit", "execute-tool"]
        },
        "description": "Execute one tool call against an inline or Tiptap Cloud document."
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://api.tiptap.dev",
      "type": "string"
    },
    {
      "key": "JWT_TOKEN",
      "value": "",
      "type": "string"
    }
  ]
}
